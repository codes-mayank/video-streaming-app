# Ignore .env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Python virtual environments (never copy between OSes)
.venv/
venv/
**/.venv/
**/venv/

# Python cache
__pycache__/
*.pyc
.mypy_cache/

# Node / Next.js (platform-specific native binaries)
node_modules/
.next/
out/
