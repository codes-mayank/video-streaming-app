DATABASE_URL=sqlite:///./video_service.db
DEBUG=false

R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET_NAME=videos
R2_PRESIGNED_EXPIRES_SECONDS=900

# Optional: if you expose videos via public bucket/domain, this becomes playback_url.
R2_PUBLIC_BASE_URL=
