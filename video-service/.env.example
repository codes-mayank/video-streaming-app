DATABASE_URL=sqlite:///./video_service.db
DEBUG=false

# Must match auth-service for JWT cookie validation
SECRET_KEY=secret-key
ACCESS_TOKEN_COOKIE_NAME=access_token

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_REGION=auto
AWS_BUCKET_NAME=videos
AWS_PRESIGNED_EXPIRES_SECONDS=900

# Optional: if you expose videos via public bucket/domain, this becomes playback_url.
AWS_PUBLIC_BASE_URL=

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_VIDEO_TOPIC=video-transcode-jobs
